# Token de autenticação do bot, gerado no Discord Developer Portal
# (discord.com/developers/applications > sua aplicação > Bot > Reset Token).
TOKEN=coloque_seu_token_do_bot_aqui

# ID do servidor (guild) do Discord onde os slash commands devem
# aparecer instantaneamente. Ative "Modo desenvolvedor" no Discord,
# clique com o botão direito no servidor e copie o ID.
# Só é usado se SYNC_GLOBAL não estiver "true".
GUILD_ID=coloque_o_id_do_seu_servidor_aqui

# true = sincroniza os slash commands globalmente (todo servidor onde
# o bot estiver, propagação de até 1h). false/vazio = sincroniza só
# no GUILD_ID acima (instantâneo, ideal pra desenvolvimento).
SYNC_GLOBAL=false
